# Example .env for Stage 4 SageMaker integration
# Copy to .env and fill values (do NOT commit secrets)

AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# SageMaker endpoint names
SAGEMAKER_LLM_ENDPOINT=llama3-nim-endpoint
SAGEMAKER_EMBEDDING_ENDPOINT=retrieval-embed-endpoint

# Optional: choose sagemaker mode for the LLM client
# CODEGUARDIAN_LLM_MODE=sagemaker
# Example .env for local development (DO NOT commit secrets to git)
CODEGUARDIAN_LLM_MODE=nim
NIM_BASE_URL="https://integrate.api.nvidia.com"
NIM_EMBEDDING_MODEL=nvidia/nv-embedcode-7b-v1
NIM_INFERENCE_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
# Fill your local keys into a private .env (do NOT commit real keys)
# NIM_API_KEY_EMBEDDING=nvapi-<your-embedding-key>
# NIM_API_KEY_INFERENCE=nvapi-<your-inference-key>
# NIM_API_KEY=nvapi-<fallback-key>

